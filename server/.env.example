PORT=4000
MONGODB_URI=mongodb://localhost:27017/ai-sme
JWT_SECRET=replace-with-long-random-string
ENCRYPTION_KEY=replace-with-32-byte-hex-string-here-0123456789abcdef0123456789abcdef
NODE_ENV=development
GROQ_API_KEY=
# Comma-separated owner emails allowed to view /api/admin/analytics.
ADMIN_EMAILS=

# Paystack billing.
# Use test keys locally/staging and live keys only in production.
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_CURRENCY=GHS
PAYSTACK_PRO_PRICE_SUBUNIT=14900
PAYSTACK_BUSINESS_PRICE_SUBUNIT=49900
# Optional, if you create recurring plans in Paystack.
PAYSTACK_PRO_PLAN_CODE=
PAYSTACK_BUSINESS_PLAN_CODE=
