# Environment Variables for Intellexa Client
# Copy this file to .env.development or .env.production and fill in your values

# Backend API URL
# Development: http://localhost:4000 (default)
# Production: Your deployed backend URL (e.g., https://api.intellexa.com)
VITE_API_URL=http://localhost:4000

# Setup Instructions:
# 1. Copy this file to .env.development for local development
# 2. Copy this file to .env.production for production builds
# 3. Update VITE_API_URL with your actual backend URL
# 4. Never commit .env.development or .env.production files